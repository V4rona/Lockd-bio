{
  "cleanUrls": true,
  "routes": [
    { "src": "/index", "dest": "/index.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/404", "dest": "/404.html" },
    { "src": "/([a-zA-Z0-9_-]+)", "dest": "/profile.html?u=$1" },
    { "handle": "error" },
    { "status": 404, "src": "/(.*)", "dest": "/404.html" }
  ]
}
